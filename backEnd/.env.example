# SSMS server name
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=Shidohim
DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Windows Authentication (same as SSMS default)
DB_TRUSTED_CONNECTION=true
DB_USERNAME=
DB_PASSWORD=

# Keep false after running database/init-all.sql in SSMS
DB_SYNCHRONIZE=false
PORT=3000
