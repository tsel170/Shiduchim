# MongoDB Atlas / external connection string (required — no local fallback)
# Include the database name after the host, e.g. ...mongodb.net/shiduchim?...
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/shiduchim?appName=CLUSTER

# Server port — use 3002 if CRA runs on 3001 (see Front end/.env.development)
PORT=3002

# JWT signing secret (change in production)
JWT_SECRET=dev-shiduchim-secret

# Allowed CORS origin for the React dev server
CORS_ORIGIN=http://localhost:3001

BODY_SIZE_LIMIT=20mb
