# MongoDB Atlas connection string (required — no local MongoDB fallback)
# Include the database name after the host, e.g. ...mongodb.net/shiduchim?...
MONGODB_URI=

# JWT signing secret (required in production — use a long random string)
JWT_SECRET=

# Server port (Render sets PORT automatically; local default is 3001)
PORT=3001

# Frontend origin(s) allowed by CORS (comma-separated for multiple)
# Production example: https://my-site.vercel.app
# Local fallback when unset: http://localhost:3000,http://localhost:3001
FRONTEND_URL=

# Optional alias for FRONTEND_URL (either works)
# CORS_ORIGIN=

# Max JSON / form body size for photo uploads
BODY_SIZE_LIMIT=20mb
