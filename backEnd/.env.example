# Local MongoDB (development):
# MONGODB_URI=mongodb://localhost:27017/shiduchim
#
# MongoDB Atlas (production) — include the DB name after the host:
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/shiduchim?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/shiduchim

# JWT signing secret (required in production — use a long random string)
JWT_SECRET=dev-shiduchim-secret

# Server port (Render sets PORT automatically; local matches FrontEnd proxy → 3002)
PORT=3002

# Frontend origin(s) allowed by CORS (comma-separated for multiple)
# Production example: https://my-site.vercel.app
# Local fallback when unset: http://localhost:3000,http://localhost:3001
FRONTEND_URL=

# Optional alias for FRONTEND_URL (either works)
# CORS_ORIGIN=

# Max JSON / form body size for photo uploads
BODY_SIZE_LIMIT=20mb
