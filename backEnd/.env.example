# MongoDB connection string (include database name)
MONGODB_URI=mongodb://localhost:27017/shiduchim
# Server port — use 3002 if CRA runs on 3001 (see Front end/.env.development)
PORT=3002

# JWT signing secret (change in production)
JWT_SECRET=dev-shiduchim-secret

# Allowed CORS origin for the React dev server
CORS_ORIGIN=http://localhost:3001
